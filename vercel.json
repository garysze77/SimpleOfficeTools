{
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/receipt.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/api/receipt",
      "dest": "/api/receipt.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
